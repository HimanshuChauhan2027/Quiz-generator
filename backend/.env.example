# Server
PORT=5000
CORS_ORIGINS=http://localhost:83

# Database (leave DATABASE_URL empty to use local SQLite file, good for interviews/demos)
# For Postgres: postgres://user:password@localhost:5432/quizdb
DATABASE_URL=

# Auth
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d

# Gemini API (get a key from https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here
